{
  "title": "期货平台 - 业务概览",
  "uid": "futures-overview",
  "tags": ["futures", "platform"],
  "timezone": "Asia/Shanghai",
  "schemaVersion": 38,
  "panels": [
    {
      "title": "服务健康状态",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "up", "legendFormat": "{{service}}"}]
    },
    {
      "title": "API请求速率",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "rate(http_server_requests_seconds_count[5m])", "legendFormat": "{{service}}"}]
    },
    {
      "title": "JVM堆内存使用率",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "jvm_memory_used_bytes{area='heap'} / jvm_memory_max_bytes{area='heap'} * 100", "legendFormat": "{{service}}"}]
    },
    {
      "title": "API错误率",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "rate(http_server_requests_seconds_count{status=~'5..'}[5m]) / rate(http_server_requests_seconds_count[5m]) * 100", "legendFormat": "{{service}}"}]
    }
  ]
}
